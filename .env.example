# Kitty Collab Board — Environment Variables
# Copy this to .env and fill in your API keys

# ─────────────────────────────────────────────────────────────
# Environment
# ─────────────────────────────────────────────────────────────
CLOWDER_ENV=dev
CLOWDER_DEBUG=true

# ─────────────────────────────────────────────────────────────
# API Keys (at least one required)
# ─────────────────────────────────────────────────────────────
# Claude (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Qwen (Alibaba DashScope)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Gemini (Google)
GEMINI_API_KEY=your_gemini_api_key_here
# or GOOGLE_API_KEY=your_google_api_key_here

# OpenAI (optional)
OPENAI_API_KEY=your_openai_api_key_here

# Ollama (local models)
OLLAMA_BASE_URL=http://localhost:11434

# ─────────────────────────────────────────────────────────────
# Board Configuration
# ─────────────────────────────────────────────────────────────
CLOWDER_BOARD_DIR=./board
CLOWDER_LOG_DIR=./logs
CLOWDER_ARCHIVE_AFTER_DAYS=30
CLOWDER_STALE_TASK_MINUTES=5
CLOWDER_HANDOFF_TIMEOUT_MINUTES=10

# ─────────────────────────────────────────────────────────────
# Agent Configuration
# ─────────────────────────────────────────────────────────────
CLOWDER_POLL_INTERVAL=5.0
CLOWDER_TASK_TIMEOUT_MINUTES=5
CLOWDER_MAX_RETRIES=3
CLOWDER_RETRY_BASE_DELAY=1.0
CLOWDER_RETRY_MAX_DELAY=60.0
CLOWDER_HEARTBEAT_INTERVAL=30.0

# ─────────────────────────────────────────────────────────────
# Web Server Configuration
# ─────────────────────────────────────────────────────────────
CLOWDER_WEB_HOST=0.0.0.0
CLOWDER_WEB_PORT=8000
CLOWDER_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CLOWDER_WEB_RELOAD=true

# ─────────────────────────────────────────────────────────────
# Alert Configuration (optional)
# ─────────────────────────────────────────────────────────────
CLOWDER_DISCORD_WEBHOOK_URL=your_discord_webhook_url_here
CLOWDER_SLACK_WEBHOOK_URL=your_slack_webhook_url_here
CLOWDER_AGENT_OFFLINE_SECONDS=300
CLOWDER_AGENT_WARNING_SECONDS=60
CLOWDER_RATE_LIMIT_WARNINGS=3
