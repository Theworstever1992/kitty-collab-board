# Kitty Collab Board — Environment Variables
# Copy this file to .env, replace ALL <PLACEHOLDER> values, then start the services.
# NEVER commit .env to version control — it is listed in .gitignore.

# ── Board (v1 + v2 shared) ────────────────────────────────────────────────────
CLOWDER_BOARD_DIR=./board

# Set to "false" in production — debug mode exposes stack traces to clients.
CLOWDER_DEBUG=false

# ── v1 Web Chat Server ────────────────────────────────────────────────────────
CLOWDER_WEB_PORT=8080

# ── v2 API Server ─────────────────────────────────────────────────────────────
CLOWDER_API_HOST=0.0.0.0
CLOWDER_API_PORT=9000

# ── PostgreSQL (v2) ───────────────────────────────────────────────────────────
# Replace <DB_USER> and <DB_PASSWORD> with strong, unique values.
# For Docker Compose (service-to-service): use the postgres service name as host.
# For local dev: use localhost.
# DATABASE_URL=postgresql+asyncpg://<DB_USER>:<DB_PASSWORD>@postgres:5432/clowder
DATABASE_URL=postgresql+asyncpg://<DB_USER>:<DB_PASSWORD>@localhost:5432/clowder

# ── RAG / Embeddings (v2 Phase 2) ─────────────────────────────────────────────
CLOWDER_EMBEDDING_MODEL=all-MiniLM-L6-v2
CLOWDER_RAG_TOP_K=5

# ── Ideas auto-surface threshold (v2 Phase 3) ─────────────────────────────────
IDEAS_AUTO_SURFACE_THRESHOLD=10
IDEAS_WINDOW_HOURS=48
