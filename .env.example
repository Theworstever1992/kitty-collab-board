# Kitty Collab Board — Environment Variables
# Copy to .env and adjust values for your setup

# ── Board (v1 + v2 shared) ────────────────────────────────────────────────────
CLOWDER_BOARD_DIR=./board
CLOWDER_DEBUG=true

# ── v1 Web Chat Server ────────────────────────────────────────────────────────
CLOWDER_WEB_PORT=8080

# ── v2 API Server ─────────────────────────────────────────────────────────────
CLOWDER_API_HOST=0.0.0.0
CLOWDER_API_PORT=9000

# ── PostgreSQL (v2) ───────────────────────────────────────────────────────────
# For Docker Compose: use service name 'postgres' as host
# DATABASE_URL=postgresql+asyncpg://clowder:clowder@postgres:5432/clowder
# For local dev: use localhost
DATABASE_URL=postgresql+asyncpg://clowder:clowder@localhost:5432/clowder

# ── RAG / Embeddings (v2 Phase 2) ─────────────────────────────────────────────
CLOWDER_EMBEDDING_MODEL=all-MiniLM-L6-v2
CLOWDER_RAG_TOP_K=5

# ── Ideas auto-surface threshold (v2 Phase 3) ─────────────────────────────────
IDEAS_AUTO_SURFACE_THRESHOLD=10
IDEAS_WINDOW_HOURS=48
